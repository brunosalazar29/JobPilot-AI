APP_NAME=JobPilot AI
ENVIRONMENT=local
SECRET_KEY=change-this-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
BACKEND_CORS_ORIGINS=http://localhost:3000

DATABASE_URL=mssql+pyodbc://sa:YourStrong!Passw0rd@sqlserver:1433/jobpilot_ai?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

UPLOAD_DIR=/app/storage/uploads
APP_AUTO_CREATE_TABLES=true
RUN_TASKS_INLINE=false
SEED_DEMO_DATA=false
PLAYWRIGHT_HEADLESS=true
ENABLE_MOCK_JOBS=false
ENABLE_ARBEITNOW_SOURCE=true
ENABLE_REMOTIVE_SOURCE=true
JOB_SOURCE_FILE=
APPLICATION_MATCH_THRESHOLD=5
AUTO_APPLY_ENABLED=true
AUTO_SUBMIT_APPLICATIONS=false

NEXT_PUBLIC_API_URL=/api
